# Loaded ONLY by `npm start` (local dev) — NOT by the production build/deploy.
# Safe to commit: contains the public backend URL only, never a secret.
# This points local dev at the live FastAPI comms backend so the Communication
# tab runs in "Live" mode. The public GitHub Pages build has no API base set, so
# it falls back to local (per-device) comms — no secret is ever baked into it.
#
# To also enable planner writes / the internal channel in local dev, add your
# planner token to .env.local (gitignored):  REACT_APP_PLANNER_TOKEN=...
REACT_APP_API_BASE_URL=https://ngw-events-api.onrender.com
