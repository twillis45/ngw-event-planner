# NGW Events API — backend-only secrets (set in Render dashboard / local .env)
# NEVER put any of these in the frontend.

# Supabase Postgres connection string (Supabase → Settings → Database → Connection string / pooler)
DATABASE_URL=
# (alias also accepted)
SUPABASE_DB_URL=

# Resend (email delivery — Sprint 58.2)
RESEND_API_KEY=
COMMUNICATION_EMAIL_FROM=events@yourdomain.com
RESEND_FROM_NAME=NGW Events

# Where approval links point (the deployed frontend)
APP_BASE_URL=https://twillis45.github.io/ngw-event-planner

# CORS — comma-separated allowed frontend origins
ALLOWED_ORIGINS=https://twillis45.github.io,http://localhost:3000

# TEMPORARY planner gate until Supabase Auth is wired (shared secret; not production auth)
PLANNER_DEV_TOKEN=
