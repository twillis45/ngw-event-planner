# ── Frontend production build config (Create React App bakes REACT_APP_* at build) ──
# Copy this file to `.env.production.local` (gitignored), fill in the values, then
# `npm run deploy`. Everything here ends up in the PUBLIC JS bundle — that's fine
# for these values (Supabase anon key + DSN are publishable by design; the real
# security boundary is the Supabase JWT + per-event ownership + Postgres RLS).
#
# Leave this file blank / don't create .env.production.local if you want the public
# demo to stay OPEN and local-storage only (no sign-in, no live backend).

# Live comms backend (Render). Non-secret.
REACT_APP_API_BASE_URL=https://ngw-events-api.onrender.com

# Supabase — Settings → API. Both non-secret (anon/publishable key).
REACT_APP_SUPABASE_URL=https://ewoggzxarpcwesqxsdoz.supabase.co
REACT_APP_SUPABASE_ANON_KEY=

# Show the "Continue with Google" button. Set to "true" ONLY after you've enabled
# the Google provider in Supabase (Authentication → Sign In / Providers → Google).
REACT_APP_ENABLE_GOOGLE_AUTH=

# Optional error monitoring — Sentry → Project → Client Keys (DSN). Non-secret.
# Leave blank to disable (no-op).
REACT_APP_SENTRY_DSN=

# NOTE: the legacy REACT_APP_PLANNER_TOKEN is for local dev only — do NOT set it
# in a public production build (it would expose the shared write gate). Once
# Supabase Auth is on, you don't need it at all.
