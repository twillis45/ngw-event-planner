# NGW Events — config (Create React App uses REACT_APP_* prefix).
# Copy this file to .env.local (which is gitignored) and fill in your values.
#
# ─── Endpoint consistency ─────────────────────────────────────────────────────
# Three URL groups must stay aligned for sign-in + invites + share links to
# work in dev:
#   1. WHERE THE APP IS SERVED FROM  (your browser bar)
#        localhost:3000          (default `npm start`)
#        192.168.1.230:3000      (LAN dev, e.g. for phone testing)
#        https://your-tunnel...  (ngrok/cloudflared)
#   2. WHERE SUPABASE REDIRECTS TO   (magic links + invites)
#        Controlled by REACT_APP_AUTH_REDIRECT below, OR window.location.origin
#        Must also appear in Supabase → Authentication → URL Configuration
#   3. WHERE SHARE LINKS POINT       (RSVP, vendor brief)
#        Computed at runtime from window.location.origin — always matches #1
#
# Rule: visit the app from the same URL your phone/teammate can reach, then
# match REACT_APP_AUTH_REDIRECT + Supabase allowlist to that URL.
#
# ── Supabase (Settings → API) ────────────────────────────────────────────────
#   - Project URL          → REACT_APP_SUPABASE_URL
#   - Project API key (anon / publishable) → REACT_APP_SUPABASE_ANON_KEY
#   NEVER put the service_role / secret key here — it would leak into the public bundle.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Optional: force the magic-link redirect URL (otherwise derived from
# window.location.origin). Set this when developing from a LAN IP or behind
# a tunnel — Supabase silently falls back to the project's Site URL when
# `emailRedirectTo` isn't on the allowlist, so the link in the email would
# end up pointing at localhost and be unusable on phones / other devices.
# Must match an entry in Supabase → Authentication → URL Configuration.
# Example: REACT_APP_AUTH_REDIRECT=http://192.168.1.230:3000/
REACT_APP_AUTH_REDIRECT=

# ── Communication backend (FastAPI) ──────────────────────────────────────────
# Public base URL of the deployed comms API. Safe to commit (lives in demo/.env).
REACT_APP_API_BASE_URL=https://ngw-events-api.onrender.com

# TEMPORARY planner dev-gate token. Must match the backend's PLANNER_DEV_TOKEN.
# SECRET — put it ONLY in .env.local for local dev. Do NOT commit it and do NOT
# bake it into the public GitHub Pages build (it would be readable by anyone).
# When unset, the Communication tab still reads the client channel but planner
# writes / the internal channel are disabled until Supabase Auth replaces this gate.
REACT_APP_PLANNER_TOKEN=

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Optional. Sentry → Project → Settings → Client Keys (DSN). A DSN is non-secret.
# When unset, Sentry is a no-op (nothing is sent). Safe to leave blank for the demo.
REACT_APP_SENTRY_DSN=
