# NGW Events — config (Create React App uses REACT_APP_* prefix).
# Copy this file to .env.local (which is gitignored) and fill in your values.
#
# ── Supabase (Settings → API) ────────────────────────────────────────────────
#   - Project URL          → REACT_APP_SUPABASE_URL
#   - Project API key (anon / publishable) → REACT_APP_SUPABASE_ANON_KEY
#   NEVER put the service_role / secret key here — it would leak into the public bundle.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# ── Communication backend (FastAPI) ──────────────────────────────────────────
# Public base URL of the deployed comms API. Safe to commit (lives in demo/.env).
REACT_APP_API_BASE_URL=https://ngw-events-api.onrender.com

# TEMPORARY planner dev-gate token. Must match the backend's PLANNER_DEV_TOKEN.
# SECRET — put it ONLY in .env.local for local dev. Do NOT commit it and do NOT
# bake it into the public GitHub Pages build (it would be readable by anyone).
# When unset, the Communication tab still reads the client channel but planner
# writes / the internal channel are disabled until Supabase Auth replaces this gate.
REACT_APP_PLANNER_TOKEN=

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Optional. Sentry → Project → Settings → Client Keys (DSN). A DSN is non-secret.
# When unset, Sentry is a no-op (nothing is sent). Safe to leave blank for the demo.
REACT_APP_SENTRY_DSN=
